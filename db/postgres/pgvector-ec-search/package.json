{
  "name": "pgvector-ec-search",
  "version": "1.0.0",
  "description": "PG Vector EC product search baseline with Drizzle and Hono",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "test": "vitest run",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed": "tsx src/seed.ts"
  },
  "keywords": [
    "pgvector",
    "postgres",
    "drizzle",
    "hono",
    "vector-search"
  ],
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.10.7",
    "postgres": "^3.4.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
